# Firebase project config
# Get from Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# FCM Web Push VAPID key
# Firebase Console → Project Settings → Cloud Messaging → Web configuration → Generate key pair
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# Service Account for Cloudflare Pages Function (FCM v1 API)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SA_EMAIL=firebase-adminsdk-fbsvc@your-project.iam.gserviceaccount.com
FIREBASE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Google Calendar integration (optional)
# Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorised JavaScript origins: https://your-app.pages.dev
# Also add the same key in Cloudflare Pages environment variables
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Stripe (subscription payments)
# stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# stripe.com → Products → Create product "Js-Grw-Up Premium" £5/month → copy Price ID
STRIPE_PRICE_ID=price_...
# stripe.com → Developers → Webhooks → Add endpoint https://js-grw-up.com/api/stripe-webhook
# Events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
