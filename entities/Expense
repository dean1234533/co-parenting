{
  "name": "Expense",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "mortgage",
        "rent",
        "child_maintenance",
        "school_fees",
        "clothing",
        "food",
        "medical",
        "activities",
        "childcare",
        "utilities",
        "other"
      ],
      "description": "Expense category"
    },
    "title": {
      "type": "string",
      "description": "What was it for"
    },
    "amount": {
      "type": "number",
      "description": "Amount in pounds"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the expense"
    },
    "paid_by": {
      "type": "string",
      "description": "Who paid"
    },
    "receipt_url": {
      "type": "string",
      "description": "Photo of the receipt"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    },
    "recurring": {
      "type": "boolean",
      "default": false,
      "description": "Is this a recurring expense"
    },
    "recurring_frequency": {
      "type": "string",
      "enum": [
        "weekly",
        "monthly",
        "yearly"
      ],
      "description": "How often it recurs"
    }
  },
  "required": [
    "title",
    "amount",
    "category"
  ]
}